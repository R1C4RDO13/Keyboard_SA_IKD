<?xml version="1.0" encoding="utf-8"?>
<!-- Phase 6: Diagnostics UI refresh — status chip, two metric cards, collapsible sensor card -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/diagnostics_coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.fossify.commons.views.MyAppBarLayout
        android:id="@+id/diagnostics_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/diagnostics_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/color_primary"
            app:menu="@menu/menu_diagnostics"
            app:title="@string/diagnostics"
            app:titleTextAppearance="@style/AppTheme.ActionBar.TitleTextStyle" />

    </org.fossify.commons.views.MyAppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/diagnostics_nested_scrollview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/diagnostics_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/activity_margin">

            <!-- Typing area -->
            <org.fossify.commons.views.MyEditText
                android:id="@+id/diagnostics_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:maxLines="6"
                android:gravity="top|start"
                android:hint="@string/diagnostics_type_here"
                android:inputType="textMultiLine|textCapSentences"
                android:scrollbars="vertical" />

            <!-- Status chip — prominent coloured indicator above metric cards -->
            <TextView
                android:id="@+id/diagnostics_status_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/normal_margin"
                android:background="@drawable/bg_status_chip"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="@string/diagnostics_capture_status_no_data"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Timing metrics card (IKD / Dwell / Flight) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/normal_margin"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/normal_margin">

                    <TextView
                        android:id="@+id/diagnostics_timing_section_label"
                        style="@style/SettingsSectionLabelStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/diagnostics_keystroke_timing" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/small_margin">

                        <org.fossify.commons.views.MyTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_ikd_label"
                            android:textStyle="bold"
                            android:minWidth="100dp" />

                        <org.fossify.commons.views.MyTextView
                            android:id="@+id/diagnostics_ikd_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_value_none" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/small_margin">

                        <org.fossify.commons.views.MyTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_dwell_label"
                            android:textStyle="bold"
                            android:minWidth="100dp" />

                        <org.fossify.commons.views.MyTextView
                            android:id="@+id/diagnostics_dwell_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_value_none" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/small_margin">

                        <org.fossify.commons.views.MyTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_flight_label"
                            android:textStyle="bold"
                            android:minWidth="100dp" />

                        <org.fossify.commons.views.MyTextView
                            android:id="@+id/diagnostics_flight_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_value_none" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Count metrics card (Events / Speed / Error Rate) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/small_margin"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/normal_margin">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <org.fossify.commons.views.MyTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_event_count_label"
                            android:textStyle="bold"
                            android:minWidth="100dp" />

                        <org.fossify.commons.views.MyTextView
                            android:id="@+id/diagnostics_event_count_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/small_margin">

                        <org.fossify.commons.views.MyTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_typing_speed_label"
                            android:textStyle="bold"
                            android:minWidth="100dp" />

                        <org.fossify.commons.views.MyTextView
                            android:id="@+id/diagnostics_typing_speed_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_value_none" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/small_margin">

                        <org.fossify.commons.views.MyTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_error_rate_label"
                            android:textStyle="bold"
                            android:minWidth="100dp" />

                        <org.fossify.commons.views.MyTextView
                            android:id="@+id/diagnostics_error_rate_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_value_none" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Sensor Readings collapsible card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/small_margin"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/normal_margin">

                    <!-- Collapsible header row -->
                    <LinearLayout
                        android:id="@+id/diagnostics_sensor_readings_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingBottom="4dp">

                        <TextView
                            android:id="@+id/diagnostics_sensor_readings_label"
                            style="@style/SettingsSectionLabelStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/diagnostics_sensor_readings_section" />

                        <ImageView
                            android:id="@+id/diagnostics_sensor_readings_chevron"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_expand_vector"
                            android:contentDescription="@null" />

                    </LinearLayout>

                    <!-- Collapsible content (gyro + accel) -->
                    <LinearLayout
                        android:id="@+id/diagnostics_sensor_readings_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Gyroscope section -->
                        <TextView
                            android:id="@+id/diagnostics_gyro_section_label"
                            style="@style/SettingsSectionLabelStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/small_margin"
                            android:text="@string/diagnostics_gyroscope_section" />

                        <LinearLayout
                            android:id="@+id/diagnostics_gyro_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Per-axis (X / Y / Z) bars — visible in AXES mode -->
                            <LinearLayout
                                android:id="@+id/diagnostics_gyro_axes_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <!-- Gyro X -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="@dimen/small_margin">

                                    <org.fossify.commons.views.MyTextView
                                        android:layout_width="16dp"
                                        android:layout_height="wrap_content"
                                        android:text="X"
                                        android:textStyle="bold" />

                                    <ProgressBar
                                        android:id="@+id/diagnostics_gyro_x_bar"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="@dimen/small_margin"
                                        android:layout_marginEnd="@dimen/small_margin"
                                        android:max="100"
                                        android:progress="50" />

                                    <org.fossify.commons.views.MyTextView
                                        android:id="@+id/diagnostics_gyro_x_value"
                                        android:layout_width="60dp"
                                        android:layout_height="wrap_content"
                                        android:text="0.00"
                                        android:gravity="end" />

                                </LinearLayout>

                                <!-- Gyro Y -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="@dimen/small_margin">

                                    <org.fossify.commons.views.MyTextView
                                        android:layout_width="16dp"
                                        android:layout_height="wrap_content"
                                        android:text="Y"
                                        android:textStyle="bold" />

                                    <ProgressBar
                                        android:id="@+id/diagnostics_gyro_y_bar"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="@dimen/small_margin"
                                        android:layout_marginEnd="@dimen/small_margin"
                                        android:max="100"
                                        android:progress="50" />

                                    <org.fossify.commons.views.MyTextView
                                        android:id="@+id/diagnostics_gyro_y_value"
                                        android:layout_width="60dp"
                                        android:layout_height="wrap_content"
                                        android:text="0.00"
                                        android:gravity="end" />

                                </LinearLayout>

                                <!-- Gyro Z -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="@dimen/small_margin">

                                    <org.fossify.commons.views.MyTextView
                                        android:layout_width="16dp"
                                        android:layout_height="wrap_content"
                                        android:text="Z"
                                        android:textStyle="bold" />

                                    <ProgressBar
                                        android:id="@+id/diagnostics_gyro_z_bar"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="@dimen/small_margin"
                                        android:layout_marginEnd="@dimen/small_margin"
                                        android:max="100"
                                        android:progress="50" />

                                    <org.fossify.commons.views.MyTextView
                                        android:id="@+id/diagnostics_gyro_z_value"
                                        android:layout_width="60dp"
                                        android:layout_height="wrap_content"
                                        android:text="0.00"
                                        android:gravity="end" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Magnitude bar — visible in MAGNITUDE mode -->
                            <LinearLayout
                                android:id="@+id/diagnostics_gyro_magnitude_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="@dimen/small_margin"
                                android:visibility="gone">

                                <org.fossify.commons.views.MyTextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="|v|"
                                    android:textStyle="bold" />

                                <ProgressBar
                                    android:id="@+id/diagnostics_gyro_magnitude_bar"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="@dimen/small_margin"
                                    android:layout_marginEnd="@dimen/small_margin"
                                    android:max="100"
                                    android:progress="0" />

                                <org.fossify.commons.views.MyTextView
                                    android:id="@+id/diagnostics_gyro_magnitude_value"
                                    android:layout_width="60dp"
                                    android:layout_height="wrap_content"
                                    android:text="0.00"
                                    android:gravity="end" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Accelerometer section -->
                        <TextView
                            android:id="@+id/diagnostics_accel_section_label"
                            style="@style/SettingsSectionLabelStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/normal_margin"
                            android:text="@string/diagnostics_accelerometer_section" />

                        <!-- Per-axis (X / Y / Z) bars — visible in AXES mode -->
                        <LinearLayout
                            android:id="@+id/diagnostics_accel_axes_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Accel X -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="@dimen/small_margin">

                                <org.fossify.commons.views.MyTextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="X"
                                    android:textStyle="bold" />

                                <ProgressBar
                                    android:id="@+id/diagnostics_accel_x_bar"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="@dimen/small_margin"
                                    android:layout_marginEnd="@dimen/small_margin"
                                    android:max="100"
                                    android:progress="50" />

                                <org.fossify.commons.views.MyTextView
                                    android:id="@+id/diagnostics_accel_x_value"
                                    android:layout_width="60dp"
                                    android:layout_height="wrap_content"
                                    android:text="0.00"
                                    android:gravity="end" />

                            </LinearLayout>

                            <!-- Accel Y -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="@dimen/small_margin">

                                <org.fossify.commons.views.MyTextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="Y"
                                    android:textStyle="bold" />

                                <ProgressBar
                                    android:id="@+id/diagnostics_accel_y_bar"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="@dimen/small_margin"
                                    android:layout_marginEnd="@dimen/small_margin"
                                    android:max="100"
                                    android:progress="50" />

                                <org.fossify.commons.views.MyTextView
                                    android:id="@+id/diagnostics_accel_y_value"
                                    android:layout_width="60dp"
                                    android:layout_height="wrap_content"
                                    android:text="0.00"
                                    android:gravity="end" />

                            </LinearLayout>

                            <!-- Accel Z -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="@dimen/small_margin">

                                <org.fossify.commons.views.MyTextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="Z"
                                    android:textStyle="bold" />

                                <ProgressBar
                                    android:id="@+id/diagnostics_accel_z_bar"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="@dimen/small_margin"
                                    android:layout_marginEnd="@dimen/small_margin"
                                    android:max="100"
                                    android:progress="50" />

                                <org.fossify.commons.views.MyTextView
                                    android:id="@+id/diagnostics_accel_z_value"
                                    android:layout_width="60dp"
                                    android:layout_height="wrap_content"
                                    android:text="0.00"
                                    android:gravity="end" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Magnitude bar — visible in MAGNITUDE mode -->
                        <LinearLayout
                            android:id="@+id/diagnostics_accel_magnitude_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="@dimen/small_margin"
                            android:visibility="gone">

                            <org.fossify.commons.views.MyTextView
                                android:layout_width="16dp"
                                android:layout_height="wrap_content"
                                android:text="|v|"
                                android:textStyle="bold" />

                            <ProgressBar
                                android:id="@+id/diagnostics_accel_magnitude_bar"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/small_margin"
                                android:layout_marginEnd="@dimen/small_margin"
                                android:max="100"
                                android:progress="0" />

                            <org.fossify.commons.views.MyTextView
                                android:id="@+id/diagnostics_accel_magnitude_value"
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="0.00"
                                android:gravity="end" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- View Event Log row -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/diagnostics_view_log_holder"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/normal_margin"
                android:layout_marginBottom="@dimen/activity_margin">

                <org.fossify.commons.views.MyTextView
                    android:id="@+id/diagnostics_view_log_label"
                    style="@style/SettingsTextLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/diagnostics_view_event_log"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <org.fossify.commons.views.MyTextView
                    android:id="@+id/diagnostics_view_log_count"
                    style="@style/SettingsTextValueStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/diagnostics_value_none"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
